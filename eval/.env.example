# =====================================================================
# Ragas 评估配置示例：复制为 .env 后填入真实值
# =====================================================================

# DashScope（阿里云百炼）API Key
# 用于：
#   1. TestsetGenerator 生成评估问题（generator_llm = qwen-max）
#   2. Ragas 计算指标时的裁判 LLM（judge_llm = qwen-max）
#   3. embedding 模型 text-embedding-v4（与项目主流程一致）
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# DashScope OpenAI 兼容接口地址（默认值，无需修改）
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 用于生成测试集和裁判的 LLM 模型
GENERATOR_MODEL=qwen-max
JUDGE_MODEL=qwen-max

# Embedding 模型（与项目一致）
EMBEDDING_MODEL=text-embedding-v4

# VideoMind 后端地址
API_BASE_URL=http://localhost:8081

# 评估账号（用于登录拿 JWT token，调用 /api/v1/eval/answer）
EVAL_AUTH_USERNAME=admin
EVAL_AUTH_PASSWORD=admin123

# Elasticsearch 连接（用于从 chunks 拉取生成测试集的源文档）
ES_URL=http://localhost:9200
ES_USERNAME=elastic
ES_PASSWORD=PaiSmart2025
ES_INDEX=knowledge_base

# 测试集生成参数
TESTSET_SIZE=20
MAX_CHUNKS_FOR_TESTSET=80

# 仅基于这些 fileMd5 生成测试集（白名单，逗号分隔），优先级高于黑名单
INCLUDE_FILE_MD5_LIST=

# 排除这些 fileMd5 不参与测试集生成（黑名单）
EXCLUDE_FILE_MD5_LIST=

# 评估时每条问题给后端检索 topK
EVAL_TOP_K=5
